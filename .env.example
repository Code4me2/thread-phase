# Inference provider — defaults assume a local vLLM (OpenAI-compatible API).
# Override these to point at any OpenAI-compatible endpoint (vLLM, OpenAI, Ollama,
# llama.cpp, etc.). The framework only assumes /v1/chat/completions semantics.

INFERENCE_BASE_URL=http://localhost:8000/v1
INFERENCE_API_KEY=not-needed-for-local-vllm
INFERENCE_MODEL=qwen3.6-27b
INFERENCE_MODEL_LIGHT=qwen3.6-27b
INFERENCE_CONTEXT_LENGTH=131072

# Persisted event log (sqlite). Used by session/job-runner for resumable streams.
THREAD_PHASE_DB=./thread-phase.db
